# --- VSS API (required for fleet data) ---
# The app tries each complete profile in order until apiLogin succeeds (status 10000).
# Primary profile:
VSS_BASE_URL=http://40.76.130.233:9966
VSS_USERNAME=your@vss-user
VSS_PASSWORD=your-password

# Secondary profile (_N suffix) — e.g. https://vss.controltech-ea.com (see howen_vss_api.ipynb):
# VSS_BASE_URL_N=https://vss.controltech-ea.com
# VSS_USERNAME_N=your@vss-user
# VSS_PASSWORD_N=your-password

# SSL verify for HTTPS VSS hosts (default off for controltech-ea.com, matches notebook verify=False):
# VSS_SSL_VERIFY=0

# Proactive token refresh: token + PID stored in .vss_token.json for this many hours (default 23):
# VSS_TOKEN_TTL_HOURS=23
# When .vss_token.json exists the app reuses it first; on 10023 it apiLogs in via .env and re-saves the file.
# Set VSS_10082_RETRY_LOGIN=1 to force login retries even when a token file exists (recovery uses this automatically).

# --- Flask dashboard login (separate from VSS credentials) ---
# FLASK_SECRET_KEY=change-me-in-production
# DHL_DASH_USERNAME=admin
# DHL_DASH_PASSWORD=dhl

# Alarm history: default is legacy findAllByTime (matches most deployments). V2.8 doc endpoint:
# VSS_ALARM_FIND_PATH=/vss/alarm/apiFindAllByTime.action

# Optional: paste a known-good token to skip login (avoids 10082 rate limit on cold start).
# VSS_TOKEN=
# VSS_PID=

# Umbrella DHL fleet in VSS (copy GUID from the fleet tree). Crawls that fleet + all child fleets.
# DHL_ROOT_FLEET_ID=
# Or explicit list: DHL_FLEET_IDS=guid-one,guid-two
# DHL_FLEET_IDS=
# If env fleets are set but /vehicle/findAll returns no rows, keyword scan is skipped (set 1 to force old behavior):
# DHL_ALLOW_KEYWORD_DEVICE_FALLBACK=1

# Dashboard bind (dev: python flask_app.py)
# Werkzeug HTTP access log (every Dash poll): default off; set 1 to print each request.
# DHL_DASH_ACCESS_LOG=1
# Background bust + refetch interval (minutes). Default 60 = 1 hour; matches data cache TTL.
# DHL_AUTO_REFRESH_MINUTES=60
# DHL_DASH_HOST=127.0.0.1
# Dev server default port is 8050 (see DEFAULT_PORT in flask_app.py).
DHL_DASH_PORT=8050

# docker compose: host port (default 8050) -> container 8050
# DHL_PUBLISH_PORT=8050

# UI polls caches every N ms so charts appear soon after data arrives (default 1000).
# DHL_UI_POLL_MS=1000
# Parallel fleet device pages during crawl (default 10, max 16 in code).
# DHL_DEVICE_FLEET_WORKERS=10
# Default -1 = poll forever; was 300 (~10 min) then charts could stay "No data" if VSS was slower.
# DHL_UI_POLL_MAX_TICKS=-1

# --- Load speed ---
# Default in code is FAST (keyword device list + shorter alarm window). For full crawl + 24h alarms:
# DHL_FAST_MODE=0
# DHL_FAST_ALARM_HOURS=2
# DHL_FAST_SKIP_ALARMS=1
# DHL_FAST_ALARM_WORKERS=4
# DHL_FAST_ALARM_MAX_PAGES=10
# Proper device crawl is fleet-based (recommended). Keyword-only is opt-in:
# DHL_FAST_DEVICE_KEYWORD_ONLY=1
# DHL_FAST_DEVICE_MAX_PAGES=25
# DHL_FAST_DEVICE_FLEET_WORKERS=6
# Optional overrides (keep max_workers <= 12 unless you know the server can take more).
# DHL_REALTIME_BATCH=10
# DHL_REALTIME_MAX_WORKERS=8

# Default: server listens immediately; data loads in background. Set 1 only to block until devices are cached.
# DHL_SYNC_BOOTSTRAP=1
# Seconds before HTTP starts even if the device list is still loading. Default 120.
# DHL_BOOTSTRAP_TIMEOUT_SEC=120

# After a successful load, device list is saved to .dhl_devices_snapshot.csv and reused if VSS fails (10082, etc.).
# DHL_DEVICE_SNAPSHOT_DISABLE=1
# DHL_DEVICE_SNAPSHOT_MAX_HOURS=168
# Use CSV as the device baseline (DeviceID / DeviceName / FleetID / Fleet) and skip VSS discovery;
# realtime + alarms still call VSS with those DeviceIDs. Path defaults to repo .dhl_devices_snapshot.csv.
# DHL_DEVICES_FROM_SNAPSHOT=1
# DHL_DEVICE_SNAPSHOT_PATH=C:\Users\Paul\Downloads\dhl_dashboard\.dhl_devices_snapshot.csv

# Jupyter positions.ipynb: if kernel cwd is not dhl_dashboard, set this to the repo folder.
# DHL_DASHBOARD_DIR=C:\Users\Paul\Downloads\dhl_dashboard

# --- MiX Telematics (optional) ---
# Enable MiX positions page + background refresh:
# MIX_ENABLED=1
# Preferred: inline JSON (same shape as accounts.json) — no file needed:
# MIX_ACCOUNTS_JSON={"mix_za":{"ApiUrl":"https://...","IdentityUrl":"...","IdentityClientId":"...","IdentityClientSecret":"...","IdentityUsername":"...","IdentityPassword":"..."}}
# Or path to accounts.json (default: ./accounts.json in this folder). Copy accounts.json.example first.
# MIX_ACCOUNTS_JSON_PATH=accounts.json
# Key inside accounts.json (default mix_za for DHL / East Africa fleet):
# MIX_SERVER_KEY=mix_za
# Comma-separated MiX group IDs (or use name filter / fetch-all below):
# MIX_GROUP_IDS=5064510706195163215
# MiX organisation id for library events API (not the site/group id in MIX_GROUP_IDS)
# MIX_ORGANISATION_ID=
# Substring match on organisation group names, e.g. DHL or TotalEnergies:
# MIX_GROUP_NAME_CONTAINS=DHL
# Pull every organisation group your MiX user can access:
# MIX_FETCH_ALL_GROUPS=1
# MIX_QUANTITY=1
# MIX_ENSURE_REVERSE_GEOCODED=1
# Enrich positions with asset name + registration (default ON; set 0 to skip extra API call):
# MIX_FETCH_ASSETS=1
# Display timezone offset hours for "Last updated" (default 3 = East Africa):
# MIX_DISPLAY_TZ_OFFSET_HOURS=3
#
# Or inline credentials (skip accounts.json):
# MIX_API_URL=
# MIX_IDENTITY_URL=
# MIX_CLIENT_ID=
# MIX_CLIENT_SECRET=
# MIX_USERNAME=
# MIX_PASSWORD=
# Speed + RPM from MiX tacho API (F1 = speed km/h, F2 = RPM on DHL devices).
# MIX_TACHO_ENRICH_POSITIONS=1
# MIX_TACHO_MINUTES=59
# MIX_TACHO_SPEED_LINE=F1
# MIX_TACHO_RPM_LINE=F2
# MiX: 7-day "Diagnostic fault no engine RPM" event scan (library + group events API)
# MIX_RPM_FAULT_DAYS=7
# MIX_RPM_FAULT_EVENT_MATCH=diagnostic fault no engine rpm,no engine rpm,fault no engine rpm
# Or set explicit EventTypeIds from /api/libraryevents/organisation/{groupId}:
# MIX_RPM_FAULT_EVENT_TYPE_IDS=
## Neon Database Connection

